from pyspark.sql import SparkSession
from pyspark.sql.types import StructType, StructField, StringType, LongType, IntegerType, DoubleType
from pyspark.sql.functions import *
import xml.etree.ElementTree as ET
import sys

# default values

candle_width = 30000
candle_date_from = 19000101
candle_date_to = 20200101
candle_time_from = 1000
candle_time_to = 1902
date_len = 8
time_len = 9
time_length = 17


# converting milliseconds to datetime

def to_time0(ms):
    ms = ms.cast("int")
    mss = ms % 1000
    ms = floor(ms / 1000).cast("int")
    ss = floor(ms % 60).cast("int")
    ms = floor(ms / 60).cast("int")
    mm = floor(ms % 60).cast("int")
    hh = floor(ms / 60).cast("int")
    return mss + ss * 1000 + mm * 100000 + hh * 10000000


if __name__ == "__main__":
    if len(sys.argv) > 1:
        path = sys.argv[1]
        tree = ET.parse(path)
        root = tree.getroot()
        for elem in root:
            globals()[elem[0].text.replace('.', '_')] = elem[1].text
        print("SUCCESS!!!!!")

    # creating SparkSession
    print("SUCCESS!")

    spark = SparkSession.builder.master("local[*]").appName("proj").getOrCreate()

    schema = StructType(fields=[
        StructField("#SYMBOL", StringType()),
        StructField("SYSTEM", StringType()),
        StructField("MOMENT", LongType()),
        StructField("ID_DEAL", LongType()),
        StructField("PRICE_DEAL", DoubleType()),
        StructField("VOLUME", IntegerType()),
        StructField("OPEN_POS", LongType()),
        StructField("DIRECTION", StringType())
    ])

    # reading file

    source_data = spark.read.csv('fin_sample.csv', header=True, schema=schema)

    # splitting datetime into date and time columns

    source_data = (source_data.select(source_data['#SYMBOL'], source_data['MOMENT'], source_data['PRICE_DEAL'])) \
        .withColumn("DATE", substring('MOMENT', 0, 8)) \
        .withColumn("TIME", substring("MOMENT", 9, time_length - 8))

    source_data.orderBy("TIME").show()

    # formatted date_from, time_from, date_to, time_to

    d1, t1, d2, t2 = str(candle_date_from), \
                     str(candle_time_from) + "0" * (time_len - len(str(candle_time_from))), \
                     str(candle_date_to), \
                     str(candle_time_to) + "0" * (time_len - len(str(candle_time_to)))

    # setting date and time bounds (filtering data)

    filtered_data = source_data.filter((col("DATE") >= d1) & (col("DATE") < d2)
                                       & (col("TIME") < t2) & (col("TIME") >= t1))

    # adding candle indexing column (convert "MOMENT" to milliseconds and division by candle_width)

    filtered_data = filtered_data.withColumn("candle", floor((substring("TIME", 0, 2) * 60 * 60 * 1000 + substring(
        "TIME", 3, 2) * 60 * 1000 + substring("TIME", 5, 2) * 1000 + substring("TIME", 7, 3)).cast(
        "int") / candle_width))

    # sort by moment

    fd = filtered_data.orderBy('MOMENT')

    # grouping by "SYMBOL" and "candle" columns and adding columns with statistics for each candle

    fd = fd.groupBy("#SYMBOL", "DATE", "candle").agg(to_time0(col('candle').cast("int") * candle_width).alias("MOMENT"),
                                                     first("PRICE_DEAL").alias("OPEN"), max("PRICE_DEAL").alias("HIGH"),
                                                     min("PRICE_DEAL").alias("LOW"),
                                                     last("PRICE_DEAL").alias("CLOSE")).sort("#SYMBOL", "candle")

    # selecting useful columns
    fd = fd.withColumnRenamed("#SYMBOL", "SYMBOL")
    fd = fd.select("SYMBOL", "MOMENT", "OPEN", "HIGH", "LOW", "CLOSE")

    # saving results

    fd.write.option("header", False) \
        .partitionBy("SYMBOL") \
        .mode("append") \
        .csv("/content/partitionBy")
